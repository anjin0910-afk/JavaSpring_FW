<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- Product 클래스를 Setter Injection으로 SpringBean 설정 -->
	<bean id="product1" class="mylab.order.Product">
		<property name="id" value="P001" />
		<property name="name" value="노트북" />
		<property name="price" value="150000" />
	</bean>

	<!-- Product 클래스를 Constructor Injection으로 SpringBean 설정 -->
	<bean id="product2" class="mylab.order.Product">
		<constructor-arg value="P002" />
		<constructor-arg value="스마트폰" />
		<constructor-arg value="800000" />
	</bean>

	<!-- ShoppingCart 클래스를 SpringBean으로 설정 -->
	<bean id="shoppingCart" class="mylab.order.ShoppingCart">
		<property name="products">
			<list>
				<ref bean="product1"/>
				<ref bean="product2"/>
			</list>
		</property>
	</bean>

	<!-- OrderService 클래스를 SpringBean으로 설정 -->
	<bean id="orderService" class="mylab.order.OrderService">
		<property name="shoppingCart" ref="shoppingCart" />
	</bean>

</beans>
